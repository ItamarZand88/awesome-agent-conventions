<!-- source: bountystrike-community — https://raw.githubusercontent.com/nilhemdot/bountystrike-community/master/.mcp.json -->
{
  "mcpServers": {
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "${DATABASE_URL}"
      ]
    },
    "scope": {
      "command": "node",
      "args": [
        "mcp/scope-mcp/dist/index.js"
      ]
    },
    "oracle": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "mcp/oracle-mcp",
        "oracle-mcp"
      ]
    },
    "dedup": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "mcp/dedup-mcp",
        "dedup-mcp"
      ],
      "env": {
        "DATABASE_URL": "${DATABASE_URL}"
      }
    },
    "state": {
